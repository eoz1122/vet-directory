# ─── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
api/venv/

# Python caches and test state
__pycache__/
*.py[cod]
.pytest_cache/

# ─── Build Output ──────────────────────────────────────────────────────────────
# The dist/ folder is generated on the VPS by running `npm run build`
# We do NOT commit it to git — the deploy.sh script builds it on the server.
dist/

# ─── Internal / Sensitive Data ─────────────────────────────────────────────────
# Internal CSV export — contains all vet data for internal use only
web-app/vets-database-internal.csv

# Local processing databases are generated by maintenance scripts
data/processing/*.db

# Environment variables (never commit secrets)
.env
.env.local
.env.production
.env.*.local

# ─── Editor & OS Artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json

# ─── Debug / Temp Files ────────────────────────────────────────────────────────
web-app/debug-vite.mjs
web-app/README.md.metadata.json
web-app/README.md.resolved
web-app/README.md.resolved.0

# ─── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
confirmations.jsonl
web-app/src/data/vets.json.bak
outreach/
